# Database provider: "supabase" (recommended for Render) | "sqlite" (local only)
VITE_DB_PROVIDER=supabase

# --- Supabase (required when VITE_DB_PROVIDER=supabase) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- AI verification (hackathon free stack) ---
# DeepSeek API key (free tier / low cost) — structures claims
# https://platform.deepseek.com/
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# Perplexity website session cookies — live web search (no paid API)
# Local: paste Cookie header into PERPLEXITY_COOKIES or data/perplexity-cookies.txt
# PERPLEXITY_COOKIES=
# PERPLEXITY_COOKIES_FILE=data/perplexity-cookies.txt
# Pipeline: DeepSeek draft → cookie Perplexity search (default when both set and no paid key)
# ANALYZE_FREE_PIPELINE=1

# Optional paid Perplexity API (real image pixels + Sonar). Leave empty for free hackathon mode.
# PERPLEXITY_API_KEY=
# PERPLEXITY_MODEL=sonar-pro
# PERPLEXITY_PREFER_COOKIES=1
# PERPLEXITY_WEB_MODEL=turbo

# --- OCR.space (server-side for POST /api/ocr) ---
# OCR_SPACE_API_KEY=
# OCR_SPACE_LANGUAGE=eng
# OCR_SPACE_ENGINE=2

