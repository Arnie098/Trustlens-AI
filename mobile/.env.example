# Environment for MOBILE web builds (device / emulator artifacts).
# Copy to the REPO ROOT as .env (or export in your shell) before running
# `npm run mobile:sync` — these values are baked into mobile/www at build time.
#
# Never embed Perplexity or server secrets in the APK. The analyze endpoint
# stays on the deployed host and is reached through VITE_API_BASE_URL.

# Use hosted Supabase on device (SQLite is local-dev only, not shippable).
VITE_DB_PROVIDER=supabase

# Your deployed Supabase project.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_KEY

# Absolute origin of your deployed TrustLens host that serves POST /api/analyze.
# Required for device builds: the bundled www/ cannot resolve a relative
# /api/analyze against a remote server without this.
VITE_API_BASE_URL=https://YOUR_DEPLOYED_TRUSTLENS_HOST
