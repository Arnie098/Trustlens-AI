# TrustLens mobile — Supabase backend (required)
EXPO_PUBLIC_DB_PROVIDER=supabase
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY

# Analyze API (web/server that hosts POST /api/analyze — never put model keys here)
EXPO_PUBLIC_API_BASE_URL=https://trustlens-ai-d3s2.onrender.com
# Local analyze while developing web API:
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# --- OCR.space (recommended) ---
# Preferred: put OCR_SPACE_API_KEY on the *web server* (.env / Render).
# Mobile calls POST {EXPO_PUBLIC_API_BASE_URL}/api/ocr — key never in the APK.
# EXPO_PUBLIC_API_BASE_URL is set above.

# Optional direct OCR.space from the phone (demo only — key is visible in the app):
# EXPO_PUBLIC_OCR_SPACE_API_KEY=your_ocr_space_key
# EXPO_PUBLIC_OCR_SPACE_LANGUAGE=eng
# EXPO_PUBLIC_OCR_SPACE_ENGINE=2

# Optional local UNESCO Tesseract (Python) — not required when using OCR.space
# EXPO_PUBLIC_OCR_URL=http://localhost:5001
# EXPO_PUBLIC_OCR_API_KEY=dev-secret
